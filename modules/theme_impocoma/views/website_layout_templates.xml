<odoo>
    <template id="impocoma_public_header" name="Impocoma Public Header" inherit_id="website.layout">
        <xpath expr="//header[@id='top']" position="replace">
            <header id="top" class="imp-public-header">
                <div class="imp-public-header__inner">
                    <a class="imp-public-header__brand" href="/" aria-label="Impocoma">
                        <img src="/theme_impocoma/static/src/img/impocoma_logo.jpeg" alt="Impocoma - Transporte de Carga Pesada"/>
                    </a>
                    <nav class="imp-public-header__nav" aria-label="Navegación principal">
                        <a class="imp-public-header__link" href="/">Inicio</a>
                        <a class="imp-public-header__link" href="/registro-conductor">Habilitación Terceros</a>
                        <a t-if="not request.env.user._is_public()" class="imp-public-header__link" href="/mis-solicitudes-riesgo">Mis habilitaciones</a>
                        <a class="imp-public-header__link" href="/contactus">Contacto</a>
                        <a t-if="request.env.user._is_public()" class="imp-public-header__auth" href="/web/login">Ingresar</a>
                        <a t-if="not request.env.user._is_public()" class="imp-public-header__auth" href="/web/session/logout?redirect=/">Salir</a>
                        <a class="imp-public-header__cta" href="/registro-conductor">Nueva habilitación</a>
                    </nav>
                    <details class="imp-public-header__mobile">
                        <summary aria-label="Abrir menú">
                            <span class="fa fa-bars"/>
                        </summary>
                        <nav class="imp-public-header__mobile-panel" aria-label="Navegación móvil">
                            <a class="imp-public-header__link" href="/">Inicio</a>
                            <a class="imp-public-header__link" href="/registro-conductor">Habilitación Terceros</a>
                            <a t-if="not request.env.user._is_public()" class="imp-public-header__link" href="/mis-solicitudes-riesgo">Mis habilitaciones</a>
                            <a class="imp-public-header__link" href="/contactus">Contacto</a>
                            <a t-if="request.env.user._is_public()" class="imp-public-header__auth" href="/web/login">Ingresar</a>
                            <a t-if="not request.env.user._is_public()" class="imp-public-header__auth" href="/web/session/logout?redirect=/">Salir</a>
                            <a class="imp-public-header__cta" href="/registro-conductor">Nueva habilitación</a>
                        </nav>
                    </details>
                </div>
            </header>
        </xpath>
    </template>

    <template id="impocoma_public_footer" name="Impocoma Public Footer" inherit_id="website.layout">
        <xpath expr="//footer[@id='bottom']" position="replace">
            <footer id="bottom" class="imp-public-footer">
                <div class="imp-public-footer__inner">
                    <section>
                        <h2 class="imp-public-footer__claim">Transporte de Carga Pesada</h2>
                        <p class="imp-public-footer__copy">
                            Compañía de logística y transporte de carga terrestre con operación nacional, ubicada en Mosquera, Cundinamarca.
                        </p>
                    </section>
                    <section>
                        <h3>Portal</h3>
                        <ul class="imp-public-footer__list">
                            <li><a href="/registro-conductor">Habilitación Terceros</a></li>
                            <li><a href="/mis-solicitudes-riesgo">Mis habilitaciones</a></li>
                            <li><a href="/web/login">Ingresar al portal</a></li>
                        </ul>
                    </section>
                    <section>
                        <h3>Contacto</h3>
                        <ul class="imp-public-footer__list">
                            <li>Mosquera, Cundinamarca</li>
                            <li><a href="/contactus">Contáctanos</a></li>
                            <li><a href="https://www.impocoma.com" target="_blank" rel="noopener">www.impocoma.com</a></li>
                        </ul>
                    </section>
                </div>
                <div class="imp-public-footer__bottom">
                    <div class="imp-public-footer__bottom-inner">
                        <span>Impocoma S.A.S.</span>
                        <span>Logística, transporte y habilitación de terceros.</span>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>
</odoo>
