<odoo>
    <record id="view_addon_record_list" model="ir.ui.view">
        <field name="name">addon.record.list</field>
        <field name="model">addon.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_addon_record_form" model="ir.ui.view">
        <field name="name">addon.record.form</field>
        <field name="model">addon.record</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_addon_record_search" model="ir.ui.view">
        <field name="name">addon.record.search</field>
        <field name="model">addon.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="active_records" string="Active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_addon_record" model="ir.actions.act_window">
        <field name="name">Addon Records</field>
        <field name="res_model">addon.record</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_addon_record_search"/>
        <field name="context">{'search_default_active_records': 1}</field>
    </record>
</odoo>
