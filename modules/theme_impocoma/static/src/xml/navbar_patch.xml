<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Replace default Apps menu click with Dashboard -->

    <t t-name="theme_impocoma.NavBar.AppsMenu"
       t-inherit="web.NavBar.AppsMenu"
       t-inherit-mode="extension">

        <xpath expr="//Dropdown" position="attributes">

            <attribute name="disabled">true</attribute>

            <attribute name="t-on-click.stop">
                onClickDashboard
            </attribute>

        </xpath>

    </t>

    <!-- Mobile Sidebar Apps Menu -->

    <t t-name="theme_impocoma.NavBar.AppsMenu.Sidebar"
       t-inherit="web.NavBar.AppsMenu.Sidebar"
       t-inherit-mode="extension">

        <xpath expr="//a" position="attributes">

            <attribute name="t-on-click.prevent">
                onClickDashboard
            </attribute>

        </xpath>

    </t>

</templates>
