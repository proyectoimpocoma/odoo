<odoo>
    <template id="impocoma_login_brand" name="Impocoma Login Brand" inherit_id="web.login">
        <xpath expr="//form[@role='form' and @data-captcha='login']" position="before">
            <div class="imp-login-brand">
                <div class="imp-login-logo">
                    <img src="/theme_impocoma/static/src/img/impocoma_logo.jpeg" alt="Impocoma - Transporte de Carga Pesada"/>
                </div>
                <p class="imp-login-eyebrow">Portal Impocoma</p>
                <h1 class="imp-login-title">Habilitación Terceros</h1>
                <p class="imp-login-copy">
                    Accede para continuar tu registro, cargar documentos o revisar el estado de tu habilitación.
                </p>
            </div>
        </xpath>
    </template>
</odoo>
